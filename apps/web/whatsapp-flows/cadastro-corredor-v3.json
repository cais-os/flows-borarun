{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "BOAS_VINDAS": ["DADOS_BASICOS"],
    "DADOS_BASICOS": ["EXPERIENCIA"],
    "EXPERIENCIA": ["DETALHES_CORRIDA", "OUTRAS_ATIVIDADES"],
    "DETALHES_CORRIDA": ["VOLUME_CORRIDA"],
    "VOLUME_CORRIDA": ["OUTRAS_ATIVIDADES"],
    "OUTRAS_ATIVIDADES": ["OBJETIVO"],
    "OBJETIVO": ["OBJETIVO_DISTANCIA", "OBJETIVO_TEMPO", "DISPONIBILIDADE"],
    "OBJETIVO_DISTANCIA": ["DISPONIBILIDADE"],
    "OBJETIVO_TEMPO": ["DISPONIBILIDADE"],
    "DISPONIBILIDADE": ["SAUDE"],
    "SAUDE": ["SAUDE_DETALHE", "CONFIRMACAO"],
    "SAUDE_DETALHE": ["CONFIRMACAO"]
  },
  "screens": [
    {
      "id": "BOAS_VINDAS",
      "title": "Bora Run",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Bem-vindo ao Bora Run!"
          },
          {
            "type": "TextBody",
            "text": "Vamos criar seu plano personalizado de corrida. Em poucos passos vamos conhecer seu perfil, experiencia e objetivos para montar o treino ideal pra voce."
          },
          {
            "type": "TextBody",
            "text": "O questionario leva cerca de 2 minutos."
          },
          {
            "type": "Footer",
            "label": "Comecar",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "DADOS_BASICOS",
      "title": "Dados Basicos",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Sobre voce"
          },
          {
            "type": "TextInput",
            "name": "idade",
            "label": "Idade",
            "input-type": "text",
            "required": true,
            "helper-text": "Ex: 30"
          },
          {
            "type": "TextInput",
            "name": "altura",
            "label": "Altura (cm)",
            "input-type": "text",
            "required": true,
            "helper-text": "Ex: 175"
          },
          {
            "type": "TextInput",
            "name": "peso",
            "label": "Peso (kg)",
            "input-type": "text",
            "required": true,
            "helper-text": "Ex: 70"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "sexo",
            "label": "Sexo",
            "required": true,
            "data-source": [
              { "id": "masculino", "title": "Masculino" },
              { "id": "feminino", "title": "Feminino" },
              { "id": "nao_informar", "title": "Prefiro nao informar" }
            ]
          },
          {
            "type": "Footer",
            "label": "Continuar",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "idade": "${form.idade}",
                "altura": "${form.altura}",
                "peso": "${form.peso}",
                "sexo": "${form.sexo}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "EXPERIENCIA",
      "title": "Experiencia",
      "data": {
        "idade": { "type": "string", "__example__": "30" },
        "altura": { "type": "string", "__example__": "175" },
        "peso": { "type": "string", "__example__": "70" },
        "sexo": { "type": "string", "__example__": "masculino" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Experiencia atual"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "ja_corre",
            "label": "Voce ja corre hoje?",
            "required": true,
            "data-source": [
              { "id": "zero", "title": "Nao, estou comecando do zero" },
              { "id": "as_vezes", "title": "Sim, corro as vezes" },
              { "id": "frequente", "title": "Sim, corro com frequencia" }
            ]
          },
          {
            "type": "Footer",
            "label": "Continuar",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "idade": "${data.idade}",
                "altura": "${data.altura}",
                "peso": "${data.peso}",
                "sexo": "${data.sexo}",
                "ja_corre": "${form.ja_corre}"
              }
            }
          }
        ]
      }
    },
    {
